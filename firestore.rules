rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /movies/{movieId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'junior.bocardi2@gmail.com';
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.token.email == 'junior.bocardi2@gmail.com' || request.auth.uid == userId);
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
